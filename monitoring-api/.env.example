API_KEY=your-strong-api-key-here

# Azure SQL Connection String
DB_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:sql-knowledgehub-dev.database.windows.net,1433;Database=db-monitoring;Uid=sqladmin;Pwd=YOUR_PASSWORD;Encrypt=yes;TrustServerCertificate=no;

